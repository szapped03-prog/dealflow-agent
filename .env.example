# ── Copy this file to ".env" and fill in the real values ──
# (the agent loads .env automatically; never commit the real .env)

# 1. Anthropic — used to extract structured deal data from each email.
#    Get one at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# 2. Supabase — the WRITE side. Must be the SERVICE ROLE key (not the anon key),
#    because the agent isn't a logged-in user and needs to bypass row-level security.
#    Supabase → Project Settings → API → "service_role" secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# 3. The shared inbox the agent reads (Gmail over IMAP).
#    GMAIL_USER  = the shared address everyone forwards deals to
#    GMAIL_APP_PASSWORD = a 16-char Google "App Password" (NOT your login password).
#       Create at https://myaccount.google.com/apppasswords
#       (requires 2-Step Verification turned on for that Google account)
GMAIL_USER=deals@yourfirm.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Which mailbox/label to read. Default INBOX. Forward rules can drop deals into a
# label like "DealFlow" — then set GMAIL_MAILBOX=DealFlow.
GMAIL_MAILBOX=INBOX

# Optional: only process mail newer than this many days (first-run safety). Default 30.
LOOKBACK_DAYS=30
